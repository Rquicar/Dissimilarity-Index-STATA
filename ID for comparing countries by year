* 
PROJECT: ID for comparing countries by year
AUTOR: Tu Nombre
DATE: 2026
SOFTWARE: STATA MP 17.0
DATA: International Social Survey Programme: Social Inequality I-V Cumulation
* Variables: C4_Padre, C4_D, country, year
* Missing values: -9 a -1 y 110
* CATEGORIES (classes): 1, 2, 3, 4
********************************************************************************
* 1. LIST OF COMBINATIONS (COUNTRY-YEAR)
* ------------------------------------------------------------------------------
use "LOCAL PATH OF THE .dta file", clear
* Create combination variable
egen id_pais_ano = group (country year)
* Save the combinations list
preserve
    collapse (first) country year, by (id_pais_ano)
    sort id_pais_ano
    tempfile lista_combos
    save `lista_combos'
restore

clear
* 2. PREPARING THE RESULTS FILES
* ------------------------------------------------------------------------------
tempfile todos_pares
clear
save `todos_pares', emptyok

tempfile todos_resumen
clear
save `todos_resumen', emptyok

* 3. PRINCIPAL LOOP
* ------------------------------------------------------------------------------
forvalues i = 1/113 {

    * Loading the list of combinations for each iteration
    use `lista_combos', clear
    
    * Verify that the file exists
    if `i' > _N {
        di "No hay más combinaciones"
        continue, break
    }
    
    * Loading the current combination
    local this_combo = id_pais_ano[`i']
    local this_pais  = country[`i']
    local this_anio  = year[`i']

    di ""
    di "======================================================================"
    di "PROCESANDO [`i'/113]: `this_pais' - `this_anio'"
    di "======================================================================"

    * Loading the original file
    use "LOCAL PATH OF THE .dta file", clear
    
    * Creating the filter
    gen filtro = (inrange(C4_Padre, 1, 4) & inrange(C4_D, 1, 4))
    
    * Using the filter
    keep if country == `this_pais' & year == `this_anio' & filtro == 1
    local N_obs = _N
    di "Casos válidos: " `N_obs'

    * Procesing if there are enough cases
    if `N_obs' >= 16 {

        * Verifying categories
        local categorias_completas = 1
        forvalues cat = 1/4 {
            count if C4_Padre == `cat'
            if r(N) == 0 local categorias_completas = 0
            count if C4_D == `cat'
            if r(N) == 0 local categorias_completas = 0
        }

        if `categorias_completas' == 1 {

            * COMPUTING IDs
            tab C4_Padre C4_D, matcell(F)
            
            matrix rowtot = J(4, 1, 0)
            forvalues r = 1/4 {
                matrix rowtot[`r', 1] = F[`r', 1] + F[`r', 2] + F[`r', 3] + F[`r', 4]
            }
            
            matrix P = F
            forvalues r = 1/4 {
                forvalues c = 1/4 {
                    matrix P[`r', `c'] = F[`r', `c'] / rowtot[`r', 1]
                }
            }

            matrix ID_lista = J(6, 4, .)
            local fila = 1
            local suma_ids = 0
            local min_id = 1
            local max_id = 0

            forvalues r = 1/3 {
                forvalues c = `=`r'+1'/4 {
                    local suma_diff = 0
                    forvalues k = 1/4 {
                        local diff_abs = abs(P[`r', `k'] - P[`c', `k'])
                        local suma_diff = `suma_diff' + `diff_abs'
                    }
                    local ID_ij = 0.5 * `suma_diff'

                    local suma_ids = `suma_ids' + `ID_ij'
                    if `ID_ij' < `min_id' local min_id = `ID_ij'
                    if `ID_ij' > `max_id' local max_id = `ID_ij'

                    matrix ID_lista[`fila', 1] = `r'
                    matrix ID_lista[`fila', 2] = `c'
                    matrix ID_lista[`fila', 3] = `ID_ij'
                    matrix ID_lista[`fila', 4] = rowtot[`r',1] + rowtot[`c',1]
                    local fila = `fila' + 1
                }
            }

            local id_prom = `suma_ids' / 6

            * Saving pairs
            clear
            svmat ID_lista
            capture rename ID_lista1 origen_i
            capture rename ID_lista2 origen_j
            capture rename ID_lista3 ID
            capture rename ID_lista4 N_par

            gen pais_code = `this_pais'
            gen ano = `this_anio'

            append using `todos_pares'
            save `todos_pares', replace

            * Saving summary
            clear
            set obs 1
            gen pais_code = `this_pais'
            gen ano = `this_anio'
            gen ID_promedio = `id_prom'
            gen ID_min = `min_id'
            gen ID_max = `max_id'
            gen N_total = `N_obs'

            append using `todos_resumen'
            save `todos_resumen', replace

            di "ID PROMEDIO = " %6.4f `id_prom'
        }
        else di "Categorías incompletas - omitida"
    }
    else di "Insuficientes casos (<16) - omitida"
}

