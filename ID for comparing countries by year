* 5. EXPORTING RESULTS IN AN EXCEL FILE WITH LABELS
* ------------------------------------------------------------------------------
local fecha = string(date(c(current_date), "DMY"), "%tdDD-NN-YYYY")
local archivo = "resultados_ID_completo_`fecha'.xlsx"

* Sheet 1: Detailed pairs (with labels)
use `todos_pares', clear
if _N > 0 {
    merge m:1 pais_code using `labels_paises', nogen
    order pais_label pais_code ano origen_i origen_j ID N_par
    sort pais_label ano origen_i origen_j
    export excel using "`archivo'", sheet("Pares_Detallados") firstrow(variables) replace
    di "Archivo de pares guardado"
}

* Sheet 2: Summary country-year (with labels)
use `todos_resumen', clear
if _N > 0 {
    merge m:1 pais_code using `labels_paises', nogen
    order pais_label pais_code ano ID_promedio ID_min ID_max N_total
    sort pais_label ano
    export excel using "`archivo'", sheet("Resumen_Pais_Ano") firstrow(variables) sheetreplace
    
    di ""
    di "**************************************************"
    di "RESUMEN DE ID PROMEDIO POR PAÍS (con labels)"
    di "**************************************************"
    tabstat ID_promedio, by(pais_label) statistics(N mean min max) format(%6.3f)
}

* Sheet 3: Comparative Matrix (countries in rows, years in columns)
use `todos_resumen', clear
if _N > 0 {
    
    * --- CORRECCIÓN: Eliminar missings antes de reshape ---
    * 1. Merging with labels
    merge m:1 pais_code using `labels_paises', nogen
    
    * 2. Verifying if there are missings
    count if missing(ano)
    if r(N) > 0 {
        di "Se encontraron " r(N) " observaciones con año missing. Eliminando..."
        drop if missing(ano)
    }
    
    * 3. Verifying duplicates
    * If there are duplicates we get the first one
    bysort pais_label ano: keep if _n == 1
    
    * 4. Reshape
    keep pais_label ano ID_promedio
    reshape wide ID_promedio, i(pais_label) j(ano)
    
    * 5. Export
    export excel using "`archivo'", sheet("Comparativo_Paises") firstrow(variables) sheetreplace
    di "Archivo comparativo guardado"
}

di ""
di "**************************************************"
di "PROCESO COMPLETADO"
di "**************************************************"
di "Archivo generado: `archivo'"
di "Ruta: `c(pwd)'/"
di ""
di "El Excel contiene 3 hojas:"
di "1. Pares_Detallados: Los 6 IDs por cada país-año"
di "2. Resumen_Pais_Ano: ID promedio por país-año"
di "3. Comparativo_Paises: Matriz de países × años"
